{
  "name": "talko",
  "private": true,
  "version": "1.13.1",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/copy-worklet.cjs && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "node scripts/copy-worklet.cjs && npm run build && electron-builder",
    "electron:build:win": "node scripts/copy-worklet.cjs && npm run build && electron-builder --win",
    "electron:build:linux": "node scripts/copy-worklet.cjs && npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.talko.app",
    "productName": "Talko",
    "asar": true,
    "asarUnpack": [
      "dist/*.wasm",
      "dist/workletProcessor.js",
       "node_modules/uiohook-napi/**"
    ],
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "artifactName": "TalkoSetup.exe"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png",
      "category": "Network",
      "artifactName": "Talko.AppImage"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs"
    ],
    "npmRebuild": true,
    "buildDependenciesFromSource": false
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.20",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "axios": "^1.13.5",
    "livekit-client": "^2.17.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
